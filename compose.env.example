# Zmienne dla `docker compose` (skopiuj do `.env` w katalogu głównym lub użyj --env-file).
# Drugi klon tego repozytorium: ustaw inną wartość COMPOSE_PROJECT_NAME (np. szczypta-smaku-kopia).
#
# Produkcja (DigitalOcean + demo.flowdoc.pl) — patrz też deploy/env.production.example
# COMPOSE_PROJECT_NAME=flowdoc-demo

COMPOSE_PROJECT_NAME=szczypta-smaku-local

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=szczypta-smaku

# Dla profilu `seed` (docker compose --profile tools run seed) — ten sam URL co w backend/.env,
# ale host `postgres` zamiast localhost, gdy seed odpala się w kontenerze:
# DATABASE_URL=postgresql://postgres:password@postgres:5432/szczypta-smaku
