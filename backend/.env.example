# Database (Prisma)
# Lokalny Postgres (np. Homebrew): zwykle port 5432.
DATABASE_URL="postgresql://postgres:password@localhost:5432/szczypta-smaku"
# Docker Compose z tego repozytorium: Postgres na hoście jest na porcie 5433 (patrz docker-compose.yml).
# DATABASE_URL="postgresql://postgres:password@localhost:5433/szczypta-smaku"

# Server (osobny port niż 25044 — mniej kolizji z innymi backendami)
PORT=25144

# Auth (JWT + cookies)
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# CORS (frontend origin for credentials) — lokalnie Vite (np. :3100); produkcja demo:
# CORS_ORIGIN=https://demo.flowdoc.pl
CORS_ORIGIN=http://localhost:3100

# Stripe (optional)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Seed first admin (optional, for db:seed)
# SEED_ADMIN_LOGIN=admin
# SEED_ADMIN_PASSWORD=Admin123!
# SEED_ADMIN_USERNAME=Administrator

# Skip auth (dev / cookie-free only): any login+password works, all admin routes open without cookies.
# Never enable in production when the app is exposed without other access control.
# SKIP_AUTH=true
